<section class="hero" id="top">
  <canvas class="hero-canvas" aria-hidden="true"></canvas>
  <div class="container">
    <p class="eyebrow">Motion design × AI-integrated production</p>
    <h1 class="h-display hero-title">
      Motion that feels simple, light — <em>and runs deep.</em>
    </h1>
    <p class="hero-lead">
      I'm Anatolii — motion designer and video editor. For eight years I've turned
      complex, expert-heavy products into video people actually watch. And because
      I direct AI models like a crew — wired straight into my tools — you get
      campaign-scale output at solo-operator speed.
    </p>
    <div class="hero-ctas">
      <a class="btn" href="#work">See the work</a>
      <a class="hero-mail" href="mailto:hello@tolimotion.com">hello@tolimotion.com →</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: clamp(64px, 9vw, 110px) clamp(32px, 5vw, 48px);
  }
  .hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
  .hero .container { position: relative; }
  .hero-title {
    font-size: clamp(44px, 6.5vw, 84px);
    max-width: 13ch;
    margin-top: 26px;
  }
  .hero-title em {
    font-style: italic;
    color: var(--green);
  }
  .hero-lead {
    margin-top: 28px;
    max-width: 62ch;
    font-family: var(--font-serif);
    font-size: clamp(17px, 1.6vw, 21px);
    line-height: 1.65;
    color: var(--soft);
  }
  .hero-ctas {
    margin-top: 32px;
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  .hero-mail { font-weight: 500; font-size: 16px; }
  .hero-mail:hover { color: var(--green); }
</style>

<script>
  /* Cursor trail: tiny keyframe diamonds in the Bauhaus scene palette spawn
     along the pointer path and dissolve when it stops. On touch, a tap gives
     a radial burst instead (a trail would fight with scrolling).
     prefers-reduced-motion disables it entirely. */
  const hero = document.querySelector<HTMLElement>('.hero');
  const canvas = document.querySelector<HTMLCanvasElement>('.hero-canvas');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (hero && canvas && !reduced) {
    const ctx = canvas.getContext('2d')!;
    const css = getComputedStyle(document.documentElement);
    const token = (name: string, fallback: string) =>
      css.getPropertyValue(name).trim() || fallback;
    /* illustration palette only (CLAUDE.md rule 3) */
    const COLORS = [
      token('--scene-red', '#D9493A'),
      token('--scene-blue', '#4E97CF'),
      token('--scene-yellow', '#EDBE4B'),
      token('--scene-pink', '#E38DA6'),
      token('--indigo', '#44518F'),
      token('--green', '#2E5E4E'),
    ];

    let dpr = 1;
    const resize = () => {
      /* a backgrounded tab can report 0×0 at load — keep the old size and
         retry on the next resize/spawn instead of collapsing the canvas */
      if (!hero.clientWidth || !hero.clientHeight) return;
      dpr = Math.min(2, window.devicePixelRatio || 1);
      canvas.width = hero.clientWidth * dpr;
      canvas.height = hero.clientHeight * dpr;
    };
    resize();
    window.addEventListener('resize', resize);

    type P = { x: number; y: number; vx: number; vy: number; t: number; life: number; s: number; a: number; rot: number; spin: number; color: string };
    const parts: P[] = [];
    const MAX = 120;
    let rafId = 0;
    let running = false;
    let last = 0;

    const tick = (now: number) => {
      const dt = Math.min(50, now - last || 16);
      last = now;
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      for (let i = parts.length - 1; i >= 0; i--) {
        const p = parts[i];
        p.t += dt;
        if (p.t >= p.life) { parts.splice(i, 1); continue; }
        p.x += p.vx * dt;
        p.y += p.vy * dt;
        p.vx *= 0.985;
        p.vy *= 0.985;
        p.rot += p.spin * dt;

        const k = p.t / p.life;               // 0 → 1 over the particle's life
        const fade = 1 - k * k;               // ease-out fade
        const size = p.s * (1 - 0.5 * k) * dpr;

        ctx.save();
        ctx.translate(p.x * dpr, p.y * dpr);
        ctx.rotate(p.rot);
        ctx.globalAlpha = p.a * fade;
        ctx.fillStyle = p.color;
        ctx.beginPath();
        ctx.moveTo(0, -size);
        ctx.lineTo(size, 0);
        ctx.lineTo(0, size);
        ctx.lineTo(-size, 0);
        ctx.closePath();
        ctx.fill();
        ctx.restore();
      }

      if (parts.length) {
        rafId = requestAnimationFrame(tick);
      } else {
        running = false;
        ctx.clearRect(0, 0, canvas.width, canvas.height);
      }
    };

    const start = () => {
      if (!canvas.width) resize();
      if (!running) {
        running = true;
        last = performance.now();
        rafId = requestAnimationFrame(tick);
      }
    };

    let prevX = 0, prevY = 0, travelled = 0, hasPrev = false;
    hero.addEventListener('pointermove', (e) => {
      if (e.pointerType === 'touch') return;
      const r = hero.getBoundingClientRect();
      const x = e.clientX - r.left;
      const y = e.clientY - r.top;
      if (!hasPrev) { prevX = x; prevY = y; hasPrev = true; return; }

      const dx = x - prevX, dy = y - prevY;
      const dist = Math.hypot(dx, dy);
      travelled += dist;
      prevX = x; prevY = y;

      // one diamond per ~14px of pointer travel
      while (travelled >= 14 && parts.length < MAX) {
        travelled -= 14;
        parts.push({
          x: x + (Math.random() - 0.5) * 10,
          y: y + (Math.random() - 0.5) * 10,
          vx: dx / 60 + (Math.random() - 0.5) * 0.04,
          vy: dy / 60 + (Math.random() - 0.5) * 0.04 - 0.015,
          t: 0,
          life: 600 + Math.random() * 500,
          s: 2.5 + Math.random() * 3.5,
          a: 0.5 + Math.random() * 0.35,
          rot: Math.random() * Math.PI,
          spin: (Math.random() - 0.5) * 0.002,
          color: COLORS[(Math.random() * COLORS.length) | 0],
        });
      }
      travelled = Math.min(travelled, 14);
      start();
    });
    hero.addEventListener('pointerleave', () => { hasPrev = false; });

    /* tap burst on touch — echoes the tap_burst trigger from the Rive spec */
    hero.addEventListener('pointerdown', (e) => {
      if (e.pointerType !== 'touch') return;
      const r = hero.getBoundingClientRect();
      const x = e.clientX - r.left;
      const y = e.clientY - r.top;
      const n = 20 + ((Math.random() * 7) | 0);
      for (let i = 0; i < n && parts.length < MAX; i++) {
        const ang = (i / n) * Math.PI * 2 + Math.random() * 0.6;
        const speed = 0.06 + Math.random() * 0.12;
        parts.push({
          x, y,
          vx: Math.cos(ang) * speed,
          vy: Math.sin(ang) * speed,
          t: 0,
          life: 1000 + Math.random() * 700,
          s: 2.5 + Math.random() * 3.5,
          a: 0.5 + Math.random() * 0.35,
          rot: Math.random() * Math.PI,
          spin: (Math.random() - 0.5) * 0.003,
          color: COLORS[(Math.random() * COLORS.length) | 0],
        });
      }
      start();
    });
  }
</script>
